# ─── Supabase ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Firebase (Phone Auth) ──────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ─── Google Drive ───────────────────────────
# Paste the full JSON service account key as a single line
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
# The root folder ID in the couple's Google Drive where photos will be stored
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-folder-id

# ─── App Config ─────────────────────────────
# The wedding ID (UUID) — set after creating the wedding in Supabase
NEXT_PUBLIC_WEDDING_ID=your-wedding-uuid
