# ─── Supabase ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Firebase (Phone Auth) ──────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ─── Google Drive (OAuth — couple's Google account) ──
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console.
# Add redirect URIs:
#   http://localhost:3000/api/auth/google/callback
#   https://<your-domain>/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
# Obtain by visiting /api/auth/google/start once and signing in as the couple.
# The callback page will display the refresh token to copy here.
GOOGLE_OAUTH_REFRESH_TOKEN=your-refresh-token
# The root folder ID in the couple's Google Drive where photos will be stored
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-folder-id

# ─── AWS Rekognition (face matching) ──────────
# IAM user with AmazonRekognitionFullAccess
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
# Logical name for the wedding's face collection (created on first use)
REKOGNITION_COLLECTION_ID=wedding-moments-faces

# ─── App Config ─────────────────────────────
# The wedding ID (UUID) — set after creating the wedding in Supabase
NEXT_PUBLIC_WEDDING_ID=your-wedding-uuid

# ─── Admin password ─────────────────────────
ADMIN_PASSWORD=your-admin-password
